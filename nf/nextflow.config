params {

  dorado_device = 'auto'

  // Required-ish
  run_id        = null
  outdir        = "outputs/nf_runs"
  publish_mode  = "copy"

    // Coords (Step 2)
  coords_parquet  = null     // required to enable Step 2
  coords_sample_n = 200000   // 0 means no sampling
  max_sites       = 2000

  // Inputs: choose one path
  fast5_dir     = null
  pod5          = null

  // Inputs: choose one path
  bam           = null
  bai           = null

  // Dorado
  ref_fa        = null
  dorado_model  = null

  // Resources / knobs
  min_mapq      = 10

  filter_coords_py = "scripts/filter_coords_by_bam_coverage.py"
    coords_parquet   = null
    coords_sample_n  = 200000
    max_sites        = 2000

    // Step 3 (extract labeled)
    extract_py         = "scripts/extract_coord_chunks_wgbs.py"
    window             = 400
    max_reads_per_site = 3     // your script default is 3; set to what you want
    limit_sites        = 0     // 0 = all (script default), else cap sites for smoke
    k                  = 9     // bookkeeping only (script is fixed at 9)

    // Step 4 (WebDataset)
    build_wds_py   = "scripts/build_webdataset_from_parquet.py"
    wds_shard_size = 512
    val_frac       = 0.2
    seed           = 7

    // Step 5 (Train)
    train_py     = "scripts/train_joint_cnn_kmer_transformer_wds_smoketest.py"
    exp_name     = "smoke"
    epochs       = 10
    batch_size   = 128
    lr           = 3e-4
    num_workers  = 0

    // Step 6 (Eval)
    eval_py          = "scripts/eval_wds_smoketest.py"
    eval_split       = "val"
    eval_batch_size  = 256
    eval_num_workers = 0
    calibrate        = false
    calib_bins       = 15
}

params.dorado_device = 'cuda:all'

params {
  dorado_device   = 'cuda:all'
  dorado_max_reads = 2000   // set 0 for full run
}

process {
  withLabel: cpu {
    cpus   = 4
    memory = '8 GB'
    time   = '2h'
  }
  withLabel: gpu {
    cpus   = 4
    memory = '8 GB'
    time   = '8h'
  }
}

profiles {
  local {
    process.executor = 'local'
  }
}